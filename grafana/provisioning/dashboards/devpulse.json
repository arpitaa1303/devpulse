{
  "title": "DevPulse Dashboard",
  "uid": "devpulse-main",
  "schemaVersion": 39,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_total{job=\"devpulse-backend\"})"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"devpulse-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"devpulse-backend\"}[5m])) * 100"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Rate (req/sec)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"devpulse-backend\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Duration (p95)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"devpulse-backend\"}[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    }
  ]
}
